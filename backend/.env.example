# Backend Environment Variables Example
# Copy this file to .env and fill in your values

# JWT Secret for token signing (use strong random value)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server port
PORT=3000

# Database Connection (Local Development with Docker)
DATABASE_URL="postgresql://postgres:1111@localhost:5434/paydaybank?schema=public"

# PostgreSQL Docker Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1111
POSTGRES_DB=paydaybank

# Encryption Keys (use strong random values)
ENCRYPTION_PASSWORD=your_encryption_password_change_this
ENCRYPTION_SALT=your_encryption_salt_change_this
HASHING_PEPPER=your_hashing_pepper_change_this

# Environment
NODE_ENV=development
