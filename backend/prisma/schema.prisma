generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User { 
  id            Int      @id @default(autoincrement()) 
  firstName     String
  surName       String
  email         String   @unique
  cardNumber    String   @unique
  cardIndex     String   @unique
  password      String
  balance       Float    @default(0)
  createdAt     DateTime   @default(now()) 
  updatedAt     DateTime   @updatedAt

  getSender    LoggingTransaction[] @relation("GetSender")
  getRecipient LoggingTransaction[] @relation("GetRecipient")
} 

model LoggingTransaction {
  id            Int      @id @default(autoincrement())
  senderId      Int
  recipientId   Int
  url           String
  method        String
  statusCode    Int
  sum           Int
  createdAt     DateTime   @default(now()) 
  updatedAt     DateTime   @updatedAt

  sender    User @relation("GetSender", fields: [senderId], references: [id])
  recipient User @relation("GetRecipient",fields: [recipientId], references: [id])
}